{
  "name": "@interline-io/catenary",
  "version": "0.1.0",
  "description": "Vue 3 UI controls library based on Bulma",
  "repository": "https://github.com/interline-io/catenary",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/catenary.js"
    },
    "./style.css": "./dist/catenary.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "nuxi dev playground",
    "dev:prepare": "nuxi prepare playground",
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "build:playground": "nuxi generate playground",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint .",
    "check": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "@mdi/font": "^7.4.0",
    "bulma": "^1.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "date-fns": "4.1.0"
  },
  "devDependencies": {
    "@mdi/font": "7.4.47",
    "@vitejs/plugin-vue": "6.0.1",
    "@vue/test-utils": "2.4.6",
    "bulma": "1.0.4",
    "h3": "1.15.1",
    "jsdom": "26.1.0",
    "nuxi": "3.30.0",
    "nuxt": "4.2.0",
    "sass": "1.86.0",
    "typescript": "5.9.3",
    "vite": "7.2.2",
    "vitest": "3.2.4",
    "vue": "3.5.22",
    "vue-tsc": "3.1.3"
  },
  "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "oxc-parser",
      "unrs-resolver"
    ]
  }
}
