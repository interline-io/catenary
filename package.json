{
  "name": "@interline-io/catenary",
  "version": "0.1.0",
  "description": "Vue 3 UI controls library based on Bulma",
  "repository": "https://github.com/interline-io/catenary",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/catenary.js"
    },
    "./style.css": "./dist/catenary.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "nuxi dev playground",
    "dev:prepare": "nuxi prepare playground",
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "build:playground": "nuxi generate playground",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "vue-tsc --noEmit && nuxi typecheck playground",
    "check": "pnpm lint && pnpm typecheck"
  },
  "peerDependencies": {
    "@mdi/font": "^7.4.0",
    "bulma": "^1.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "dependencies": {
    "csv-stringify": "^6.7.0",
    "date-fns": "4.1.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@mdi/font": "7.4.47",
    "@nuxt/eslint-config": "1.10.0",
    "@stylistic/eslint-plugin": "5.5.0",
    "@vitejs/plugin-vue": "6.0.1",
    "@vue/test-utils": "2.4.6",
    "axe-core": "4.12.0",
    "bulma": "1.0.4",
    "eslint": "9.39.4",
    "eslint-plugin-vue": "10.5.1",
    "eslint-plugin-vuejs-accessibility": "2.5.0",
    "h3": "1.15.9",
    "jsdom": "26.1.0",
    "nuxi": "3.30.0",
    "nuxt": "4.4.6",
    "sass": "1.86.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.3",
    "vite": "7.3.2",
    "vitest": "4.1.8",
    "vue": "3.5.22",
    "vue-eslint-parser": "10.2.0",
    "vue-router": "4.6.4",
    "vue-tsc": "3.1.3"
  },
  "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "oxc-parser",
      "unrs-resolver"
    ],
    "overrides": {
      "postcss@<8.5.10": "^8.5.10",
      "js-cookie@<3.0.7": "^3.0.7",
      "simple-git@<3.36.0": "^3.36.0"
    }
  }
}
